@model IEnumerable<InventoryMapper.Core.Entities.Blueprint>
@{
    ViewData["Title"] = "Blueprints";
    var byLocation = Model
        .GroupBy(b => b.Location?.Name ?? "Unassigned")
        .OrderBy(g => g.Key == "Unassigned" ? 1 : 0)
        .ThenBy(g => g.Key)
        .ToList();
}

<div class="page-content">
    <div class="page-header">
        <div>
            <h1 class="page-title">Infrastructure Blueprints</h1>
            <p class="page-subtitle">Floor plans, datacenter maps &amp; virtual space layouts</p>
        </div>
        <a asp-controller="Blueprints" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-upload"></i> Upload Blueprint
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="empty-state" style="padding: 64px 24px;">
                <div class="empty-icon"><i class="fas fa-map"></i></div>
                <div class="empty-title">No Blueprints Yet</div>
                <div class="text-sm" style="margin-bottom: 16px;">Upload a floor plan or datacenter layout to start placing assets</div>
                <a asp-controller="Blueprints" asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-upload"></i> Upload First Blueprint
                </a>
            </div>
        </div>
    }
    else
    {
        foreach (var group in byLocation)
        {
            <div style="margin-bottom: 32px;">
                <!-- Location group header -->
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid var(--border-color);">
                    <i class="fas @(group.Key == "Unassigned" ? "fa-question-circle" : "fa-building")"
                       style="color: @(group.Key == "Unassigned" ? "var(--text-muted)" : "var(--accent-blue)"); font-size: 16px;"></i>
                    <span style="font-size: 15px; font-weight: 600; color: @(group.Key == "Unassigned" ? "var(--text-muted)" : "var(--text-primary)");">
                        @group.Key
                    </span>
                    <span style="font-size: 12px; color: var(--text-muted); background: var(--bg-tertiary); border-radius: 12px; padding: 2px 10px; border: 1px solid var(--border-color);">
                        @group.Count() blueprint@(group.Count() == 1 ? "" : "s")
                    </span>
                    @if (group.Key != "Unassigned")
                    {
                        <a asp-controller="Locations" asp-action="Index" style="margin-left: auto; font-size: 12px; color: var(--text-muted);">
                            <i class="fas fa-external-link-alt"></i> View Location
                        </a>
                    }
                </div>

                <div class="grid-3" style="gap: 16px;">
                    @foreach (var bp in group)
                    {
                        <div class="card" style="cursor: pointer; transition: transform 0.2s, border-color 0.2s;"
                             onmouseover="this.style.transform='translateY(-2px)';this.style.borderColor='var(--accent-blue)'"
                             onmouseout="this.style.transform='';this.style.borderColor='var(--border-color)'">
                            <div style="height: 160px; background: var(--bg-tertiary); display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--border-color); overflow: hidden; position: relative;">
                                @if (bp.MimeType?.StartsWith("image/") == true)
                                {
                                    <img src="@bp.FileStoragePath" alt="@bp.Name" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.7;" />
                                }
                                else
                                {
                                    <div style="text-align: center; color: var(--text-muted);">
                                        <i class="fas fa-file-pdf" style="font-size: 40px;"></i>
                                        <div class="text-sm" style="margin-top: 8px;">PDF Blueprint</div>
                                    </div>
                                }
                                <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.7); border-radius: 6px; padding: 3px 8px; font-size: 11px; color: white;">
                                    @bp.PlacedAssets.Count asset(s) placed
                                </div>
                            </div>
                            <div class="card-body">
                                <div style="font-weight: 600; margin-bottom: 2px;">@bp.Name</div>
                                @if (!string.IsNullOrEmpty(bp.Description))
                                {
                                    <div class="text-sm text-muted" style="margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@bp.Description</div>
                                }
                                <div class="text-sm text-muted" style="margin-bottom: 12px;">@(bp.FileSizeBytes / 1024) KB · @((int)bp.CanvasWidth)×@((int)bp.CanvasHeight)</div>
                                <div class="flex gap-2">
                                    <a asp-controller="Blueprints" asp-action="Canvas" asp-route-id="@bp.Id"
                                       class="btn btn-primary btn-sm" style="flex: 1; justify-content: center;">
                                        <i class="fas fa-map"></i> Open Canvas
                                    </a>
                                    <a asp-controller="Blueprints" asp-action="Edit" asp-route-id="@bp.Id"
                                       class="btn btn-secondary btn-sm" title="Edit blueprint settings">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-controller="Blueprints" asp-action="Delete" asp-route-id="@bp.Id"
                                          method="post" onsubmit="return confirm('Delete @bp.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
