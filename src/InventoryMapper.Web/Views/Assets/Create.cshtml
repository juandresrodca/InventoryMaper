@model InventoryMapper.Core.DTOs.CreateAssetDto
@{
    ViewData["Title"] = "New Asset";
}

<div class="page-content">
    <div class="page-header">
        <div>
            <div class="breadcrumb">
                <a asp-controller="Assets" asp-action="Index">Assets</a>
                <span class="breadcrumb-sep">/</span>
                <span>New Asset</span>
            </div>
            <h1 class="page-title">Create Asset</h1>
        </div>
    </div>

    <form asp-controller="Assets" asp-action="Create" method="post" style="max-width: 900px;">
        @Html.AntiForgeryToken()

        <div class="card" style="margin-bottom: 16px;">
            <div class="card-header"><span class="card-title">Identity</span></div>
            <div class="card-body">
                <div class="form-grid-3">
                    <div class="form-group">
                        <label class="form-label">Hostname *</label>
                        <input asp-for="Hostname" class="form-control" placeholder="WS-HQ-001" required />
                        <span asp-validation-for="Hostname" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">IP Address</label>
                        <input asp-for="IpAddress" class="form-control" placeholder="10.0.1.100" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">MAC Address</label>
                        <input asp-for="MacAddress" class="form-control" placeholder="AA:BB:CC:DD:EE:FF" />
                    </div>
                </div>
                <div class="form-grid-3">
                    <div class="form-group">
                        <label class="form-label">Serial Number</label>
                        <input asp-for="SerialNumber" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Asset Type *</label>
                        <select asp-for="AssetType" class="form-control">
                            @foreach (var t in (ViewBag.AssetTypes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)!)
                            { <option value="@t.Value">@t.Text</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select asp-for="Status" class="form-control">
                            @foreach (var s in (ViewBag.Statuses as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)!)
                            { <option value="@s.Value">@s.Text</option> }
                        </select>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Manufacturer</label>
                        <input asp-for="Manufacturer" class="form-control" placeholder="Dell, HP, Cisco..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Model</label>
                        <input asp-for="Model" class="form-control" placeholder="OptiPlex 7090..." />
                    </div>
                </div>
            </div>
        </div>

        <div class="card" style="margin-bottom: 16px;">
            <div class="card-header"><span class="card-title">System</span></div>
            <div class="card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Operating System</label>
                        <input asp-for="OperatingSystem" class="form-control" placeholder="Windows 11 Pro" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">OS Version</label>
                        <input asp-for="OsVersion" class="form-control" placeholder="22H2" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card" style="margin-bottom: 16px;">
            <div class="card-header"><span class="card-title">Organization</span></div>
            <div class="card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Assigned User</label>
                        <input asp-for="AssignedUser" class="form-control" placeholder="jsmith" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Department</label>
                        <input asp-for="Department" class="form-control" placeholder="IT, Finance..." />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Organizational Unit (OU)</label>
                    <input asp-for="OrganizationalUnit" class="form-control" placeholder="OU=Workstations,DC=corp,DC=local" />
                </div>
                <div class="form-group">
                    <label class="form-label">Location</label>
                    <select asp-for="LocationId" class="form-control">
                        <option value="">— Select Location —</option>
                        @foreach (var item in (ViewBag.Locations as Microsoft.AspNetCore.Mvc.Rendering.SelectList)!)
                        { <option value="@item.Value">@item.Text</option> }
                    </select>
                </div>
            </div>
        </div>

        <div class="card" style="margin-bottom: 16px;">
            <div class="card-header"><span class="card-title">Monitoring</span></div>
            <div class="card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Monitoring Method</label>
                        <select asp-for="MonitoringMethod" class="form-control">
                            @foreach (var m in (ViewBag.MonitoringMethods as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)!)
                            { <option value="@m.Value">@m.Text</option> }
                        </select>
                    </div>
                    <div class="form-group" style="display: flex; align-items: center; padding-top: 24px;">
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                            <input asp-for="IsMonitored" type="checkbox" style="width: 16px; height: 16px;" />
                            <span>Enable Monitoring</span>
                        </label>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional notes..."></textarea>
                </div>
            </div>
        </div>

        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create Asset</button>
            <a asp-controller="Assets" asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
